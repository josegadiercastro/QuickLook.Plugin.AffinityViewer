<UserControl x:Class="QuickLook.Plugin.AffinityViewer.AffinityPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent"
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Área de previsualización: imagen con zoom (rueda) y paneo (arrastrar) -->
        <Border Grid.Row="0" Background="#1E1E1E" ClipToBounds="True">
            <ScrollViewer x:Name="ScrollHost"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="ScrollHost_PreviewMouseWheel"
                          PreviewMouseLeftButtonDown="ScrollHost_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="ScrollHost_PreviewMouseMove"
                          PreviewMouseLeftButtonUp="ScrollHost_PreviewMouseLeftButtonUp">
                <Grid>
                    <Image x:Name="PreviewImage"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           UseLayoutRounding="True"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                        <Image.LayoutTransform>
                            <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
                        </Image.LayoutTransform>
                    </Image>

                    <!-- Mensaje mostrado cuando no se pudo extraer ninguna vista previa -->
                    <StackPanel x:Name="FallbackPanel"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="480">
                        <TextBlock x:Name="FallbackIcon"
                                   Text="🎨"
                                   FontSize="64"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16" />
                        <TextBlock x:Name="FallbackTitle"
                                   Text="Sin vista previa disponible"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <TextBlock x:Name="FallbackDetail"
                                   FontSize="13"
                                   Foreground="#BBBBBB"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Barra de estado inferior con información del archivo -->
        <Border Grid.Row="1" Background="#2A2A2A" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="InfoText"
                           Grid.Column="0"
                           Foreground="#CCCCCC"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock x:Name="SourceBadge"
                           Grid.Column="1"
                           Foreground="#888888"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
